{
  "system_info": {
    "architecture": "DTCore_v2_Lite",
    "version": "1.0",
    "total_pes": 64,
    "frequency_mhz": 400
  },

  "hardware_constraints": {
    "regfile": {
      "banks": 2,
      "bank_names": ["LOW", "HIGH"],
      "depth_per_bank": 1024,
      "width_bits": 128
    },
    "agu": {
      "count": 4,
      "slot_binding": {
        "0": {"bank": "LOW", "type": "ACT"},
        "1": {"bank": "HIGH", "type": "ACT"},
        "2": {"bank": "LOW", "type": "WGT"},
        "3": {"bank": "HIGH", "type": "WGT"}
      },
      "priority_groups": {
        "high_priority": [0, 1],
        "low_priority": [2, 3]
      }
    }
  },

  "timing_model": {
    "description": "Pipeline latency in cycles derived from Notepad.pdf",
    "frontend": {
      "decode_latency": 2,
      "issue_latency": 1,
      "instruction_fetch_gap": 0
    },
    "datapath": {
      "r_r_to_tile_arrival": 3,
      "pe_enable_delay": 1
    },
    "writeback": {
      "t_wb_pipeline_depth": 3,
      "stages": ["DA_Select", "Reorder", "Write_RAM"]
    },
    "safety": {
      "requires_double_sync": true,
      "double_sync_reason": "Signal stability check for T_ENC and continuous R_R "
    }
  },

  "compute_modes": {
    "description": "Mode definitions and execution latency (N=3)",
    "SPARSE_1_4": {
      "mode_bits": 0, 
      "latency": 3,
      "agu_mode": 0,
      "desc": "Sparsity 1:4 (N cycles)"
    },
    "SPARSE_2_4": {
      "mode_bits": 4,
      "latency": 4,
      "agu_mode": 1,
      "desc": "Sparsity 2:4 (N+1 cycles)"
    },
    "SPARSE_3_4": {
      "mode_bits": 8,
      "latency": 5,
      "agu_mode": 2,
      "desc": "Sparsity 3:4 (N+2 cycles)"
    },
    "DENSE_4_4": {
      "mode_bits": 12,
      "latency": 6,
      "agu_mode": 3,
      "desc": "Dense 4:4 (N+3 cycles)"
    },
    "SIMD": {
      "mode_bits": 1,
      "latency": 3,
      "agu_mode": 0,
      "desc": "SIMD Mode (N cycles)"
    },
    "SCALE": {
      "mode_bits": 14,
      "latency": 5,
      "desc": "Scale Mode (Fixed 5 cycles)"
    }
  },

  "wb_patterns": {
    "description": "Mapping for T_WB DABus and Reorder fields based on [MSB:LSB] format. [cite: 96-103]",
    
    "ROW_0": {
      "da_bus": [0, 0, 0, 0],
      "reorder": [3, 2, 1, 0],
      "desc": "Access Row 0 [(0,3), (0,2), (0,1), (0,0)]"
    },
    "ROW_1": {
      "da_bus": [1, 1, 1, 1],
      "reorder": [2, 1, 0, 3],
      "desc": "Access Row 1 [(1,3), (1,2), (1,1), (1,0)]"
    },
    "ROW_2": {
      "da_bus": [2, 2, 2, 2],
      "reorder": [1, 0, 3, 2],
      "desc": "Access Row 2 [(2,3), (2,2), (2,1), (2,0)]"
    },
    "ROW_3": {
      "da_bus": [3, 3, 3, 3],
      "reorder": [0, 3, 2, 1],
      "desc": "Access Row 3 [(3,3), (3,2), (3,1), (3,0)]"
    },

    "COL_0": {
      "da_bus": [1, 2, 3, 0],
      "reorder": [1, 2, 3, 0],
      "desc": "Access Col 0 [(3,0), (2,0), (1,0), (0,0)]"
    },
    "COL_1": {
      "da_bus": [2, 3, 0, 1],
      "reorder": [2, 3, 0, 1],
      "desc": "Access Col 1 [(3,1), (2,1), (1,1), (0,1)]"
    },
    "COL_2": {
      "da_bus": [3, 0, 1, 2],
      "reorder": [3, 0, 1, 2],
      "desc": "Access Col 2 [(3,2), (2,2), (1,2), (0,2)]"
    },
    "COL_3": {
      "da_bus": [0, 1, 2, 3],
      "reorder": [0, 1, 2, 3],
      "desc": "Access Col 3 [(3,3), (2,3), (1,3), (0,3)]"
    }
  }
}